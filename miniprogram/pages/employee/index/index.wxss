/* 统计行 */
.stats-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.stats-card {
  flex: 1;
  background: #C62828;
  border-radius: 20rpx;
  padding: 32rpx 20rpx;
  margin: 0 10rpx;
  text-align: center;
  border: none;
}

.stats-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

.btn-generate {
  margin-bottom: 32rpx;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  border: 1rpx solid #E5E5E5;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #A3A3A3;
  position: relative;
  border-bottom: 4rpx solid transparent;
  transition: all 0.2s;
}

.tab-item.active {
  color: #171717;
  border-bottom-color: #171717;
  font-weight: 600;
}

.tab-badge {
  display: inline-block;
  background: #C62828;
  color: #fff;
  font-size: 20rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  border-radius: 18rpx;
  padding: 0 8rpx;
  margin-left: 8rpx;
  font-weight: 600;
}

/* 列表项 */
.visit-item {
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  border: 1rpx solid #E5E5E5;
  position: relative;
}

.visit-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  background: #171717;
  border-radius: 0 4rpx 4rpx 0;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #171717;
}

.item-info {
  font-size: 26rpx;
  color: #737373;
  margin-bottom: 8rpx;
}

.item-purpose {
  font-size: 24rpx;
  color: #A3A3A3;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}

/* 月份筛选 */
.month-filter {
  margin-bottom: 24rpx;
}

.month-picker {
  display: inline-flex;
  align-items: center;
  background: #fff;
  border: 1rpx solid #E2E8F0;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.month-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A2A3A;
  margin-right: 12rpx;
}

.month-arrow {
  font-size: 20rpx;
  color: #94A3B8;
}
