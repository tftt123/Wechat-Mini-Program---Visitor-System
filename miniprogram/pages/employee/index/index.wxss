.stats-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.stats-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  margin: 0 10rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.stats-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #1976d2;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 26rpx;
  color: #666;
}

.btn-generate {
  margin-bottom: 30rpx;
}

.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: #1976d2;
  border-bottom-color: #1976d2;
  font-weight: 500;
}

.tab-badge {
  display: inline-block;
  background: #f44336;
  color: #fff;
  font-size: 22rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  border-radius: 18rpx;
  padding: 0 8rpx;
  margin-left: 8rpx;
}

.visit-item {
  margin-bottom: 20rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.item-info {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.item-purpose {
  font-size: 26rpx;
  color: #999;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f5f5f5;
}
