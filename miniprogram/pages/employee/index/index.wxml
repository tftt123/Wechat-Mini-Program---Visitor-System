<view class="container">
  <!-- 统计卡片 -->
  <view class="stats-row">
    <view class="stats-card" bindtap="switchTab" data-tab="pending">
      <view class="stats-num">{{stats.pending}}</view>
      <view class="stats-label">待确认</view>
    </view>
    <view class="stats-card">
      <view class="stats-num">{{stats.today}}</view>
      <view class="stats-label">今日来访</view>
    </view>
    <view class="stats-card">
      <view class="stats-num">{{stats.total}}</view>
      <view class="stats-label">全部记录</view>
    </view>
  </view>

  <!-- Tab切换 -->
  <view class="tab-bar">
    <view class="tab-item {{currentTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">
      待确认
      <text wx:if="{{stats.pending > 0}}" class="tab-badge"></text>
    </view>
    <view class="tab-item {{currentTab === 'today' ? 'active' : ''}}" bindtap="switchTab" data-tab="today">
      今日来访
    </view>
    <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">
      全部记录
    </view>
  </view>

  <!-- 待确认列表 -->
  <view class="list" wx:if="{{currentTab === 'pending'}}">
    <view class="card visit-item {{item.status === 'pending' ? 'card-highlight' : ''}}" wx:for="{{pendingList}}" wx:key="visitId" bindtap="goToDetail" data-id="{{item.visitId}}">
      <view class="item-header">
        <text class="item-name">{{item.visitorName || '未填写姓名'}}</text>
        <text class="status-tag {{item.statusInfo.class}}">{{item.statusInfo.text}}</text>
      </view>
      <view class="item-meta" wx:if="{{item.visitorCompany || item.purpose}}">
        <text class="item-company-purpose">{{item.visitorCompany || ''}} {{item.visitorCompany && item.purpose ? '·' : ''}} {{item.purpose || ''}}</text>
      </view>
      <view class="item-divider"></view>
      <view class="item-detail-row">
        <text class="item-detail-text">{{item.visitorPhone || '未填写电话'}}</text>
      </view>
      <view class="item-detail-row">
        <text class="item-detail-text">{{item.visitDate}} {{item.visitTime}}</text>
      </view>
      <view class="arrow-right">›</view>
    </view>
    <view class="empty-state" wx:if="{{pendingList.length === 0}}">
      <view class="empty-state-icon">📋</view>
      <view class="empty-state-text">暂无待确认拜访</view>
    </view>
    <view class="list-footer" wx:if="{{pendingList.length > 0}}">
      <text class="list-footer-text">已显示 {{pendingList.length}} 条</text>
    </view>
  </view>

  <!-- 今日来访列表 -->
  <view class="list" wx:if="{{currentTab === 'today'}}">
    <view class="card visit-item" wx:for="{{todayList}}" wx:key="visitId" bindtap="goToDetail" data-id="{{item.visitId}}">
      <view class="item-header">
        <text class="item-name">{{item.visitorName || '未填写姓名'}}</text>
        <text class="status-tag {{item.statusInfo.class}}">{{item.statusInfo.text}}</text>
      </view>
      <view class="item-meta" wx:if="{{item.visitorCompany || item.purpose}}">
        <text class="item-company-purpose">{{item.visitorCompany || ''}} {{item.visitorCompany && item.purpose ? '·' : ''}} {{item.purpose || ''}}</text>
      </view>
      <view class="item-divider"></view>
      <view class="item-detail-row">
        <text class="item-detail-text">预计时间：{{item.visitTime}}</text>
      </view>
      <view class="arrow-right">›</view>
    </view>
    <view class="empty-state" wx:if="{{todayList.length === 0}}">
      <view class="empty-state-icon">📋</view>
      <view class="empty-state-text">今日暂无来访</view>
    </view>
    <view class="list-footer" wx:if="{{todayList.length > 0}}">
      <text class="list-footer-text">已显示 {{todayList.length}} 条</text>
    </view>
  </view>

  <!-- 全部记录列表 -->
  <view class="list" wx:if="{{currentTab === 'all'}}">
    <view class="month-filter">
      <picker mode="date" fields="year-month" value="{{currentMonth}}" bindchange="onMonthChange">
        <view class="month-picker">
          <text class="month-label">{{currentMonth}}</text>
          <text class="month-arrow">▼</text>
        </view>
      </picker>
    </view>
    <view class="card visit-item {{item.status === 'pending' ? 'card-highlight' : ''}}" wx:for="{{allList}}" wx:key="visitId" bindtap="goToDetail" data-id="{{item.visitId}}">
      <view class="item-header">
        <text class="item-name">{{item.visitorName || '未填写姓名'}}</text>
        <text class="status-tag {{item.statusInfo.class}}">{{item.statusInfo.text}}</text>
      </view>
      <view class="item-meta" wx:if="{{item.visitorCompany || item.purpose}}">
        <text class="item-company-purpose">{{item.visitorCompany || ''}} {{item.visitorCompany && item.purpose ? '·' : ''}} {{item.purpose || ''}}</text>
      </view>
      <view class="item-divider"></view>
      <view class="item-detail-row">
        <text class="item-detail-text">{{item.visitDate}} {{item.visitTime}}</text>
      </view>
      <view class="arrow-right">›</view>
    </view>
    <view class="empty-state" wx:if="{{allList.length === 0}}">
      <view class="empty-state-icon">📋</view>
      <view class="empty-state-text">暂无记录</view>
    </view>
    <view class="list-footer" wx:if="{{allList.length > 0}}">
      <text class="list-footer-text">已显示 {{allList.length}} 条</text>
    </view>
  </view>
</view>