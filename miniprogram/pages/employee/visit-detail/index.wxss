@import "../../../app.wxss";

/* 访客头部 */
.visit-header {
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-border);
  margin-bottom: 12rpx;
}

.visit-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.visit-name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.visit-company {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* Timeline 内容 */
.timeline-content {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.timeline-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 4rpx;
}

.timeline-time {
  font-size: 24rpx;
  color: var(--color-text-muted);
  font-weight: 400;
}

.timeline-action {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.timeline-operator {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.timeline-role {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

/* 当前节点样式 */
.timeline-item.current .timeline-action {
  color: var(--color-text-secondary);
}

/* 操作区 */
.action-area {
  margin-top: 24rpx;
}

.action-group {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* 表单 textarea */
.form-textarea {
  height: 160rpx;
  padding: 20rpx 24rpx;
  line-height: 1.5;
}

/* 照片网格 */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}

.photo-item {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  border: 1rpx solid var(--color-border);
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  background: var(--color-surface);
  color: var(--color-danger);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1;
  box-shadow: var(--shadow-card);
}

.upload-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--color-text-muted);
}

.upload-icon {
  font-size: 40rpx;
  font-weight: 300;
  line-height: 1;
  color: var(--color-text-muted);
}

.upload-text {
  font-size: 22rpx;
  margin-top: 4rpx;
}

/* 已上传照片预览 */
.photo-preview-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.photo-preview-item {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  border: 1rpx solid var(--color-border);
}

.photo-preview-item image {
  width: 100%;
  height: 100%;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(26,42,58,0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 84%;
  max-width: 640rpx;
  background: var(--color-surface);
  border-radius: var(--radius-md);
  z-index: 101;
  overflow: hidden;
  box-shadow: var(--shadow-modal);
}

.modal-title {
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
  color: var(--color-text-primary);
}

.modal-body {
  padding: 32rpx 24rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  padding: 20rpx 24rpx 24rpx;
  gap: 16rpx;
  border-top: 1rpx solid var(--color-border);
}

.modal-btn {
  flex: 1;
}
