.detail-card {
  margin-bottom: 30rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 600;
}

.detail-section {
  margin-bottom: 30rpx;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1976d2;
  margin-bottom: 16rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid #f8f8f8;
}

.detail-row:last-child {
  border-bottom: none;
}

.row-label {
  color: #999;
}

.row-value {
  color: #333;
  font-weight: 500;
}

.log-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #666;
  border-bottom: 1rpx solid #f8f8f8;
}

.btn-group {
  margin-top: 20rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  z-index: 101;
  overflow: hidden;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-body {
  padding: 30rpx;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  height: 80rpx;
}

/* 照片网格 */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.photo-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.photo-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
}

.photo-add-icon {
  font-size: 48rpx;
  line-height: 1;
}

.photo-add-text {
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* 已上传照片预览 */
.photo-preview-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.photo-preview-item {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.photo-preview-item image {
  width: 100%;
  height: 100%;
}
