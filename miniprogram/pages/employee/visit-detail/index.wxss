.detail-card {
  margin-bottom: 32rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #171717;
}

.detail-section {
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.detail-section:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #171717;
  margin-bottom: 20rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.detail-row:last-child {
  border-bottom: none;
}

.row-label {
  color: #737373;
}

.row-value {
  color: #171717;
  font-weight: 500;
}

.log-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #737373;
  border-bottom: 1rpx solid #F5F5F5;
}

.log-item:last-child {
  border-bottom: none;
}

.btn-group {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  max-width: 640rpx;
  background: #fff;
  border-radius: 24rpx;
  z-index: 101;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.12);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F1F5F9;
  color: #1E293B;
}

.modal-body {
  padding: 32rpx;
}

.modal-footer {
  display: flex;
  padding: 24rpx 32rpx 32rpx;
  gap: 20rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  height: 80rpx;
}

/* 照片网格 */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.photo-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.photo-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #CBD5E1;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #94A3B8;
  background: #F8FAFC;
}

.photo-add-icon {
  font-size: 48rpx;
  line-height: 1;
}

.photo-add-text {
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* 已上传照片预览 */
.photo-preview-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.photo-preview-item {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #E2E8F0;
}

.photo-preview-item image {
  width: 100%;
  height: 100%;
}
