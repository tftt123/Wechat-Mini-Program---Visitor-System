.detail-card {
  margin-bottom: 30rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 600;
}

.detail-section {
  margin-bottom: 30rpx;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1976d2;
  margin-bottom: 16rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid #f8f8f8;
}

.detail-row:last-child {
  border-bottom: none;
}

.row-label {
  color: #999;
}

.row-value {
  color: #333;
  font-weight: 500;
}

.log-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #666;
  border-bottom: 1rpx solid #f8f8f8;
}

.btn-group {
  margin-top: 20rpx;
}
