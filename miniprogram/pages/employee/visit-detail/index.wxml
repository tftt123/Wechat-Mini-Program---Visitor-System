<view class="container">
  <block wx:if="{{detail}}">
    <view class="card detail-card">
      <view class="detail-header">
        <text class="detail-title">拜访详情</text>
        <text class="status-tag {{detail.statusInfo.class}}">{{detail.statusInfo.text}}</text>
      </view>

      <view class="detail-section">
        <view class="section-title">访客信息</view>
        <view class="detail-row"><text class="row-label">姓名</text><text class="row-value">{{detail.visitorName || '未填写'}}</text></view>
        <view class="detail-row"><text class="row-label">手机号</text><text class="row-value">{{detail.visitorPhone || '未填写'}}</text></view>
        <view class="detail-row"><text class="row-label">公司</text><text class="row-value">{{detail.visitorCompany || '未填写'}}</text></view>
      </view>

      <view class="detail-section">
        <view class="section-title">拜访信息</view>
        <view class="detail-row"><text class="row-label">日期时间</text><text class="row-value">{{detail.visitDate}} {{detail.visitTime}}</text></view>
        <view class="detail-row"><text class="row-label">来访目的</text><text class="row-value">{{detail.purpose || '未填写'}}</text></view>
        <view class="detail-row"><text class="row-label">邀请码</text><text class="row-value">{{detail.inviteCode}}</text></view>
      </view>

      <view class="detail-section">
        <view class="section-title">被访人信息</view>
        <view class="detail-row"><text class="row-label">姓名</text><text class="row-value">{{detail.employeeName}}</text></view>
        <view class="detail-row"><text class="row-label">部门</text><text class="row-value">{{detail.department || '未填写'}}</text></view>
      </view>

      <view class="detail-section" wx:if="{{detail.checkedInAtStr}}">
        <view class="section-title">入厂记录</view>
        <view class="detail-row"><text class="row-label">入厂时间</text><text class="row-value">{{detail.checkedInAtStr}}</text></view>
      </view>

      <view class="detail-section" wx:if="{{detail.itemsCarried !== null}}">
        <view class="section-title">物品确认</view>
        <view class="detail-row"><text class="row-label">携带物品</text><text class="row-value">{{detail.itemsCarried ? '是' : '否'}}</text></view>
        <view class="detail-row" wx:if="{{detail.itemDescription}}"><text class="row-label">物品说明</text><text class="row-value">{{detail.itemDescription}}</text></view>
      </view>

      <view class="detail-section" wx:if="{{detail.checkedOutAtStr}}">
        <view class="section-title">出厂记录</view>
        <view class="detail-row"><text class="row-label">出厂时间</text><text class="row-value">{{detail.checkedOutAtStr}}</text></view>
      </view>

      <view class="detail-section" wx:if="{{detail.logs.length > 0}}">
        <view class="section-title">操作日志</view>
        <view class="log-item" wx:for="{{detail.logs}}" wx:key="_id">
          <text class="log-action">{{item.action}}</text>
          <text class="log-operator">{{item.operatorName}} ({{item.operatorRole}})</text>
        </view>
      </view>
    </view>

    <button wx:if="{{canConfirm}}" class="btn btn-primary" bindtap="confirmVisit">确认拜访</button>

    <view wx:if="{{canItemCheck}}" class="btn-group">
      <button class="btn btn-success" bindtap="itemCheck" data-type="no">不携带物品</button>
      <button class="btn btn-danger mt-2" bindtap="itemCheck" data-type="yes">携带物品</button>
    </view>
  </block>
</view>