.visitor-landing {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 80rpx 40rpx 60rpx;
  box-sizing: border-box;
}

.header-section {
  text-align: center;
  margin-bottom: 60rpx;
  color: #171717;
}

.logo-wrapper {
  width: 200rpx;
  height: 200rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 40rpx;
  overflow: hidden;
  border: 2rpx solid #E5E5E5;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.logo-img {
  width: 160rpx;
  height: 160rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
  color: #171717;
}

.subtitle {
  font-size: 28rpx;
  color: #737373;
  font-weight: 400;
}

.input-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
}

.invite-input {
  text-align: center;
  font-size: 44rpx;
  letter-spacing: 12rpx;
  height: 120rpx;
  margin-bottom: 32rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  border: 2rpx solid #E2E8F0;
  color: #1E293B;
  font-weight: 600;
}

.invite-input::placeholder {
  font-size: 36rpx;
  letter-spacing: 4rpx;
  color: #94A3B8;
  font-weight: 400;
}

.enter-btn {
  background: #C62828;
  color: #fff;
  border-radius: 16rpx;
  font-weight: 600;
  font-size: 32rpx;
}

.enter-btn:active {
  background: #B71C1C;
}

.tip-text {
  text-align: center;
  color: #94A3B8;
  font-size: 24rpx;
  margin-top: 24rpx;
}

.divider-line {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
  color: #94A3B8;
  font-size: 26rpx;
}

.divider-line::before,
.divider-line::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #E2E8F0;
}

.divider-line::before { margin-right: 24rpx; }
.divider-line::after { margin-left: 24rpx; }

.scan-btn {
  background: #fff;
  border: 2rpx solid #E2E8F0;
  color: #1A2A3A;
  border-radius: 16rpx;
  font-weight: 500;
}

.scan-btn:active {
  background: #F8FAFC;
}
