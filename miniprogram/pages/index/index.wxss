.visitor-landing {
  min-height: 100vh;
  background: linear-gradient(180deg, #1976d2 0%, #f5f5f5 40%);
  padding: 60rpx 40rpx 40rpx;
  box-sizing: border-box;
}

.header-section {
  text-align: center;
  margin-bottom: 60rpx;
  color: #fff;
}

.logo-wrapper {
  width: 180rpx;
  height: 180rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
  overflow: hidden;
}

.logo-img {
  width: 160rpx;
  height: 160rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.input-section {
  padding: 40rpx;
}

.invite-input {
  text-align: center;
  font-size: 40rpx;
  letter-spacing: 8rpx;
  height: 100rpx;
  margin-bottom: 30rpx;
}

.tip-text {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  margin-top: 20rpx;
}

.divider-line {
  position: relative;
  text-align: center;
  margin: 40rpx 0;
}

.divider-line::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 1px;
  background: #ddd;
}

.divider-text {
  position: relative;
  background: #f5f5f5;
  padding: 0 20rpx;
  color: #999;
  font-size: 28rpx;
}

.scan-btn {
  background: #fff;
}
