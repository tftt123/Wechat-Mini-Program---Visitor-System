@import "../../../app.wxss";

/* Tab 栏 - 门卫端同款 */
.tab-bar {
  display: flex;
  background: var(--color-surface);
  border-radius: var(--radius-sm);
  padding: 4rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--color-border);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: var(--color-text-muted);
  border-radius: var(--radius-sm);
  position: relative;
}

.tab-item.active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 500;
}

/* 统计行 2x2 网格 */
.stats-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stats-card {
  background: var(--color-surface);
  border-radius: var(--radius-md);
  padding: 24rpx;
  text-align: center;
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
}

.stats-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.2;
}

.stats-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

/* 搜索条 */
.search-bar {
  margin-bottom: 24rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 4rpx 4rpx 4rpx 24rpx;
  box-shadow: var(--shadow-card);
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  background: transparent;
  border: none;
}

.search-input::placeholder {
  color: var(--color-text-muted);
}

.search-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 32rpx;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  font-weight: 500;
}

.search-btn:active {
  background: var(--color-primary-hover);
}

/* 列表项 */
.visit-item {
  position: relative;
  padding-right: 48rpx;
  margin-bottom: 16rpx;
}

.visit-item:active {
  background: #FAFBFC;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

/* 元信息行 */
.item-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.item-company-purpose {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 列表项内分割线 */
.item-divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 12rpx 0;
}

/* 详情信息行 */
.item-detail-row {
  margin-top: 8rpx;
}

.item-detail-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* 右侧箭头 */
.arrow-right {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  color: var(--color-border);
  font-size: 32rpx;
  font-weight: 300;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-state-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-state-text {
  color: var(--color-text-muted);
  font-size: 28rpx;
}

/* 列表底部统计 */
.list-footer {
  text-align: center;
  padding: 24rpx 0;
}

.list-footer-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}
