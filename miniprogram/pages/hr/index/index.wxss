.filter-card {
  margin-bottom: 32rpx;
}

.filter-row {
  display: flex;
  align-items: center;
}

.stats-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.stats-card {
  background: #C62828;
  border-radius: 20rpx;
  padding: 32rpx 20rpx;
  text-align: center;
  border: none;
}

.stats-num {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

.visit-item {
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  border: 1rpx solid #E5E5E5;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #171717;
}

.item-info {
  font-size: 26rpx;
  color: #737373;
  margin-bottom: 8rpx;
}
