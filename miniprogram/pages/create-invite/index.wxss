@import "../../app.wxss";

.result-card {
  text-align: center;
  padding: 80rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 1rpx solid #E5E5E5;
  margin-bottom: 32rpx;
}

.result-title {
  font-size: 28rpx;
  color: #737373;
  margin-bottom: 32rpx;
  font-weight: 500;
}

.result-code {
  font-size: 80rpx;
  font-weight: 700;
  color: #171717;
  letter-spacing: 16rpx;
  margin-bottom: 32rpx;
  background: #F5F5F5;
  padding: 32rpx;
  border-radius: 16rpx;
  border: 1rpx solid #E5E5E5;
}

.result-tip {
  font-size: 24rpx;
  color: #A3A3A3;
  margin-bottom: 48rpx;
}

.result-info {
  font-size: 28rpx;
  color: #737373;
  margin-bottom: 16rpx;
}
