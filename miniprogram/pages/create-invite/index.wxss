@import "../../app.wxss";

/* 结果卡片 */
.result-card {
  text-align: center;
  padding: 48rpx 32rpx;
}

/* 邀请码区域 - 浅灰底卡片 */
.invite-code-section {
  background: var(--color-background);
  border-radius: var(--radius-md);
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
}

/* 邀请码大字符 - 按设计规范 48rpx 700字重 */
.invite-code-display {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: 16rpx;
  text-align: center;
  line-height: 1.2;
}

/* 有效期 */
.invite-code-validity {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* 生成成功动画 */
.result-animate .invite-code-section {
  animation: codeAppear 200ms ease-out;
}

@keyframes codeAppear {
  0% {
    transform: scale(0.95);
    opacity: 0.8;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 提示文字 */
.result-tip {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-bottom: 24rpx;
}

/* 信息行 */
.result-info {
  font-size: 26rpx;
  margin-bottom: 8rpx;
  color: var(--color-text-secondary);
}

/* 按钮组 */
.action-group {
  display: flex;
  flex-direction: column;
  gap: 0;
}
