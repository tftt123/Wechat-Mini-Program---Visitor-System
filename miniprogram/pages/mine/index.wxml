<view class="mine-page">
  <view class="card header-section">
    <image class="logo-img" src="/images/SPINDEX_HRZ_FA.png" mode="aspectFit" />
    <view class="user-name">{{userInfo ? userInfo.name : '访客'}}</view>
    <view class="role-tag" wx:if="{{userInfo}}">{{roleText}}</view>
    <view class="user-phone" wx:if="{{userInfo}}">{{userInfo.phone}}</view>
    <view class="user-hint" wx:else>请点击登录</view>
  </view>

  <view class="card menu-card" wx:if="{{isLoggedIn}}">
    <view class="menu-item" bindtap="goToCreateInvite" wx:if="{{userInfo.role !== 'security'}}">
      <view class="menu-icon-wrap">
        <text class="menu-icon-inner">邀</text>
      </view>
      <text class="menu-text">发起邀请</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="divider" wx:if="{{userInfo.role !== 'security'}}"></view>
    <view class="menu-item" bindtap="logout">
      <view class="menu-icon-wrap menu-icon-danger">
        <text class="menu-icon-inner">退</text>
      </view>
      <text class="menu-text">退出登录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="card menu-card" wx:if="{{!isLoggedIn}}">
    <view class="menu-item" bindtap="showLoginPanel">
      <view class="menu-icon-wrap">
        <text class="menu-icon-inner">登</text>
      </view>
      <text class="menu-text">登录</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="divider"></view>
    <view class="menu-item" bindtap="showRegisterPanel">
      <view class="menu-icon-wrap">
        <text class="menu-icon-inner">注</text>
      </view>
      <text class="menu-text">注册账号</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 登录弹窗 -->
  <view class="modal-mask" wx:if="{{showLogin}}" bindtap="closePanel"></view>
  <view class="modal-content" wx:if="{{showLogin}}">
    <view class="modal-title">登录</view>
    <view class="modal-body">
      <view class="form-group">
        <text class="form-label">手机号</text>
        <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{loginPhone}}" bindinput="onLoginPhoneInput" />
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn btn-ghost modal-btn" bindtap="closePanel">取消</button>
      <button class="btn btn-primary modal-btn" bindtap="doLogin">登录</button>
    </view>
  </view>

  <!-- 注册弹窗 -->
  <view class="modal-mask" wx:if="{{showRegister}}" bindtap="closePanel"></view>
  <view class="modal-content" wx:if="{{showRegister}}">
    <view class="modal-title">注册账号</view>
    <view class="modal-body">
      <view class="form-group">
        <text class="form-label form-label-required">手机号</text>
        <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{regForm.phone}}" data-field="phone" bindinput="onRegInput" />
      </view>
      <view class="form-group">
        <text class="form-label form-label-required">姓名</text>
        <input class="form-input" placeholder="请输入姓名" value="{{regForm.name}}" data-field="name" bindinput="onRegInput" />
      </view>
      <view class="form-group">
        <text class="form-label">角色</text>
        <picker value="{{['employee','hr','security','it'].indexOf(regForm.role)}}" range="{{['员工','人事','门卫','IT']}}" bindchange="onRoleChange">
          <view class="form-input picker-value">{{regForm.role === 'employee' ? '员工' : regForm.role === 'hr' ? '人事' : regForm.role === 'it' ? 'IT' : '门卫'}}</view>
        </picker>
      </view>
      <view class="form-group">
        <text class="form-label">部门</text>
        <input class="form-input" placeholder="请输入部门" value="{{regForm.department}}" data-field="department" bindinput="onRegInput" />
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn btn-ghost modal-btn" bindtap="closePanel">取消</button>
      <button class="btn btn-primary modal-btn" bindtap="doRegister">注册</button>
    </view>
  </view>
</view>
