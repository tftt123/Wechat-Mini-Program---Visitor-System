@import "../../app.wxss";

.mine-page {
  min-height: 100vh;
  background: var(--color-background);
  padding: 32rpx;
  padding-bottom: 40rpx;
}

/* 头部区域 - 白底卡片，无红色渐变 */
.header-section {
  text-align: center;
  padding: 48rpx 32rpx;
}

.logo-img {
  width: 280rpx;
  height: 72rpx;
  margin: 0 auto 24rpx;
  display: block;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: var(--color-text-primary);
}

/* 角色标签 - 深色 pill */
.role-tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: var(--radius-pill);
  background: var(--color-primary);
  color: #fff;
  font-size: 22rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.user-phone {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  font-weight: 400;
}

.user-hint {
  font-size: 28rpx;
  color: var(--color-text-muted);
  font-weight: 400;
}

/* 菜单卡片 */
.menu-card {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: var(--color-surface);
  position: relative;
  transition: background 0.15s;
}

.menu-item:active {
  background: #FAFBFC;
}

/* 深色圆形图标（主色调） */
.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  background: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

/* 危险操作图标用红色（退出登录） */
.menu-icon-danger {
  background: var(--color-danger);
}

.menu-icon-inner {
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--color-border);
  font-weight: 300;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(26,42,58,0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 84%;
  max-width: 640rpx;
  background: var(--color-surface);
  border-radius: var(--radius-md);
  z-index: 101;
  overflow: hidden;
  box-shadow: var(--shadow-modal);
}

.modal-title {
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
  color: var(--color-text-primary);
}

.modal-body {
  padding: 32rpx 24rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  padding: 20rpx 24rpx 24rpx;
  gap: 16rpx;
  border-top: 1rpx solid var(--color-border);
}

.modal-btn {
  flex: 1;
}
