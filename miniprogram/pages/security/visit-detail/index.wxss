.detail-card {
  margin-bottom: 30rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 600;
}

.detail-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1976d2;
  margin-bottom: 16rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid #f8f8f8;
}

.row-label {
  color: #999;
}

.row-value {
  color: #333;
  font-weight: 500;
}

/* 详情页内联编辑 */
.edit-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.escort-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
  height: 60rpx;
  margin-left: 20rpx;
}

.escort-picker {
  flex: 1;
  margin-left: 20rpx;
  text-align: right;
}

.escort-picker .picker-value {
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  font-size: 28rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  height: 80rpx;
}

/* 已上传照片预览 */
.photo-preview-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.photo-preview-item {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.photo-preview-item image {
  width: 100%;
  height: 100%;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 80%; max-width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  z-index: 101;
  overflow: hidden;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-body {
  padding: 30rpx;
}

.modal-tip {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
}

/* 单选 */
.radio-group {
  display: flex;
  gap: 20rpx;
}

.radio-item {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  font-size: 28rpx;
  color: #666;
}

.radio-active {
  border-color: #1976d2;
  background: #e3f2fd;
  color: #1976d2;
  font-weight: 600;
}
