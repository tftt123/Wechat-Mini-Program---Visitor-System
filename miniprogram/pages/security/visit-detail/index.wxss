.detail-card {
  margin-bottom: 32rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #171717;
}

.detail-section {
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.detail-section:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #171717;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  font-size: 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.detail-row:last-child {
  border-bottom: none;
}

.row-label {
  color: #737373;
}

.row-value {
  color: #171717;
  font-weight: 500;
}

/* 详情页内联编辑 */
.edit-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.edit-row:last-child {
  border-bottom: none;
}

.escort-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #171717;
  height: 60rpx;
  margin-left: 20rpx;
}

.escort-picker {
  flex: 1;
  margin-left: 20rpx;
  text-align: right;
}

.escort-picker .picker-value {
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  font-size: 28rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  height: 80rpx;
}

/* 已上传照片预览 */
.photo-preview-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.photo-preview-item {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #E5E5E5;
}

.photo-preview-item image {
  width: 100%;
  height: 100%;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 80%; max-width: 640rpx;
  background: #fff;
  border-radius: 24rpx;
  z-index: 101;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.12);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #F5F5F5;
  color: #171717;
}

.modal-body {
  padding: 32rpx;
}

.modal-tip {
  font-size: 28rpx;
  color: #737373;
  margin-bottom: 32rpx;
}

.modal-footer {
  display: flex;
  padding: 24rpx 32rpx 32rpx;
  gap: 20rpx;
}

/* 单选 */
.radio-group {
  display: flex;
  gap: 20rpx;
}

.radio-item {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 16rpx;
  border: 2rpx solid #E5E5E5;
  font-size: 28rpx;
  color: #737373;
  background: #F5F5F5;
  transition: all 0.2s;
}

.radio-active {
  border-color: #171717;
  background: #E5E5E5;
  color: #171717;
  font-weight: 600;
}
