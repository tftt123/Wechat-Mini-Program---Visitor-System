@import "../../../app.wxss";

/* 访客头部 */
.visit-header {
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--color-border);
  margin-bottom: 12rpx;
}

.visit-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.visit-name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.visit-company {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* 操作区 */
.action-area {
  margin-top: 24rpx;
}

/* 已上传照片预览 */
.photo-preview-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.photo-preview-item {
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  border: 1rpx solid var(--color-border);
}

.photo-preview-item image {
  width: 100%;
  height: 100%;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(26,42,58,0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 84%; max-width: 640rpx;
  background: var(--color-surface);
  border-radius: var(--radius-md);
  z-index: 101;
  overflow: hidden;
  box-shadow: var(--shadow-modal);
}

.modal-title {
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
  color: var(--color-text-primary);
}

.modal-body {
  padding: 32rpx 24rpx;
}

.modal-footer {
  display: flex;
  padding: 20rpx 24rpx 24rpx;
  gap: 16rpx;
  border-top: 1rpx solid var(--color-border);
}

.modal-btn {
  flex: 1;
}

/* 回收工牌节点（重点设计） */
.badge-section {
  text-align: center;
  padding: 40rpx 32rpx;
  background: var(--color-surface);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-elevated);
  border: 1rpx solid var(--color-border);
}

.badge-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--color-brand-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
}

.badge-icon {
  font-size: 56rpx;
  line-height: 1;
}

.badge-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.badge-desc {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-bottom: 32rpx;
}

/* 单选按钮组（水平排列） */
.radio-group {
  display: flex;
  gap: 16rpx;
  justify-content: center;
}

.radio-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: var(--radius-sm);
  border: 2rpx solid var(--color-border);
  background: var(--color-surface);
  transition: all 0.2s;
  gap: 12rpx;
}

.radio-circle {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid var(--color-border);
  background: var(--color-surface);
  position: relative;
  flex-shrink: 0;
}

.radio-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

/* 选中态 - 实心圆 */
.radio-active {
  border-color: var(--color-primary);
  background: #FAFBFC;
}

.radio-active .radio-circle {
  border-color: var(--color-primary);
  background: var(--color-primary);
  border-width: 2rpx;
}

.radio-active .radio-label {
  color: var(--color-text-primary);
  font-weight: 500;
}
