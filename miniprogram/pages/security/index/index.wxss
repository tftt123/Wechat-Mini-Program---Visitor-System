@import "../../employee/index/index.wxss";

/* 门卫 Tab 栏 - 红色背景 + 白色文字 */
.tab-bar {
  display: flex;
  background: #C62828;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  border: none;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  position: relative;
  border-bottom: 4rpx solid transparent;
  transition: all 0.2s;
}

.tab-item.active {
  color: #FFFFFF;
  border-bottom-color: #FFFFFF;
  font-weight: 600;
}

.tab-badge {
  display: inline-block;
  background: #FFFFFF;
  color: #C62828;
  font-size: 20rpx;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  border-radius: 18rpx;
  padding: 0 8rpx;
  margin-left: 8rpx;
  font-weight: 600;
}
