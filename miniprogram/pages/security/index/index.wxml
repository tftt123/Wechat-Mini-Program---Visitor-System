<view class="container">
  <view class="page-title">今日来访管理</view>

  <view class="tab-bar">
    <view class="tab-item {{currentTab === 'toCheckIn' ? 'active' : ''}}" bindtap="switchTab" data-tab="toCheckIn">
      待入厂
      <text wx:if="{{toCheckIn.length > 0}}" class="tab-badge"></text>
    </view>
    <view class="tab-item {{currentTab === 'checkedIn' ? 'active' : ''}}" bindtap="switchTab" data-tab="checkedIn">
      已入厂
    </view>
    <view class="tab-item {{currentTab === 'toCheckOut' ? 'active' : ''}}" bindtap="switchTab" data-tab="toCheckOut">
      待出厂
      <text wx:if="{{toCheckOut.length > 0}}" class="tab-badge"></text>
    </view>
    <view class="tab-item {{currentTab === 'checkedOut' ? 'active' : ''}}" bindtap="switchTab" data-tab="checkedOut">
      已出厂
    </view>
  </view>

  <view class="list" wx:if="{{currentTab === 'toCheckIn'}}">
    <view class="card visit-item" wx:for="{{toCheckIn}}" wx:key="visitId" bindtap="goToDetail" data-id="{{item.visitId}}">
      <view class="item-header">
        <text class="item-name">{{item.visitorName}}</text>
      </view>
      <view class="item-meta">
        <text class="status-tag {{item.statusInfo.class}}">{{item.statusInfo.text}}</text>
        <text class="item-company-purpose" wx:if="{{item.visitorCompany || item.purpose}}">{{item.visitorCompany}} · {{item.purpose}}</text>
      </view>
      <view class="item-divider"></view>
      <view class="item-detail-row">
        <text class="item-detail-text">被访人：{{item.employeeName}} {{item.department}}</text>
      </view>
      <view class="item-detail-row">
        <text class="item-detail-text">手机：{{item.visitorPhone}}</text>
      </view>
      <view class="item-detail-row">
        <text class="item-detail-text">预计时间：{{item.visitTime}}</text>
      </view>
      <view class="arrow-right">›</view>
    </view>
    <view class="empty-state" wx:if="{{toCheckIn.length === 0}}">
      <view class="empty-state-icon">📋</view>
      <view class="empty-state-text">暂无待入厂访客</view>
    </view>
    <view class="list-footer" wx:if="{{toCheckIn.length > 0}}">
      <text class="list-footer-text">已显示 {{toCheckIn.length}} 条，共 {{toCheckIn.length}} 条</text>
    </view>
  </view>

  <view class="list" wx:if="{{currentTab === 'checkedIn'}}">
    <view class="card visit-item" wx:for="{{checkedIn}}" wx:key="visitId" bindtap="goToDetail" data-id="{{item.visitId}}">
      <view class="item-header">
        <text class="item-name">{{item.visitorName}}</text>
      </view>
      <view class="item-meta">
        <text class="status-tag {{item.statusInfo.class}}">{{item.statusInfo.text}}</text>
        <text class="item-company-purpose" wx:if="{{item.visitorCompany || item.purpose}}">{{item.visitorCompany}} · {{item.purpose}}</text>
      </view>
      <view class="item-divider"></view>
      <view class="item-detail-row">
        <text class="item-detail-text">被访人：{{item.employeeName}}</text>
      </view>
      <view class="item-detail-row">
        <text class="item-detail-text">入厂时间：{{item.checkedInAt ? item.checkedInAt.split('T')[1].substring(0,5) : ''}}</text>
      </view>
      <view class="arrow-right">›</view>
    </view>
    <view class="empty-state" wx:if="{{checkedIn.length === 0}}">
      <view class="empty-state-icon">📋</view>
      <view class="empty-state-text">暂无在厂访客</view>
    </view>
    <view class="list-footer" wx:if="{{checkedIn.length > 0}}">
      <text class="list-footer-text">已显示 {{checkedIn.length}} 条，共 {{checkedIn.length}} 条</text>
    </view>
  </view>

  <view class="list" wx:if="{{currentTab === 'toCheckOut'}}">
    <view class="card visit-item" wx:for="{{toCheckOut}}" wx:key="visitId" bindtap="goToDetail" data-id="{{item.visitId}}">
      <view class="item-header">
        <text class="item-name">{{item.visitorName}}</text>
      </view>
      <view class="item-meta">
        <text class="status-tag {{item.statusInfo.class}}">{{item.statusInfo.text}}</text>
        <text class="item-company-purpose" wx:if="{{item.visitorCompany || item.purpose}}">{{item.visitorCompany}} · {{item.purpose}}</text>
      </view>
      <view class="item-divider"></view>
      <view class="item-detail-row">
        <text class="item-detail-text">被访人：{{item.employeeName}}</text>
      </view>
      <view class="item-detail-row" wx:if="{{item.itemsCarried}}">
        <text class="item-detail-text">携带物品：{{item.itemDescription || '未说明'}}</text>
      </view>
      <view class="item-detail-row" wx:else>
        <text class="item-detail-text">未携带物品</text>
      </view>
      <view class="arrow-right">›</view>
    </view>
    <view class="empty-state" wx:if="{{toCheckOut.length === 0}}">
      <view class="empty-state-icon">📋</view>
      <view class="empty-state-text">暂无待出厂访客</view>
    </view>
    <view class="list-footer" wx:if="{{toCheckOut.length > 0}}">
      <text class="list-footer-text">已显示 {{toCheckOut.length}} 条，共 {{toCheckOut.length}} 条</text>
    </view>
  </view>

  <view class="list" wx:if="{{currentTab === 'checkedOut'}}">
    <view class="card visit-item" wx:for="{{checkedOut}}" wx:key="visitId" bindtap="goToDetail" data-id="{{item.visitId}}">
      <view class="item-header">
        <text class="item-name">{{item.visitorName}}</text>
      </view>
      <view class="item-meta">
        <text class="status-tag {{item.statusInfo.class}}">{{item.statusInfo.text}}</text>
        <text class="item-company-purpose" wx:if="{{item.visitorCompany || item.purpose}}">{{item.visitorCompany}} · {{item.purpose}}</text>
      </view>
      <view class="item-divider"></view>
      <view class="item-detail-row">
        <text class="item-detail-text">被访人：{{item.employeeName}}</text>
      </view>
      <view class="arrow-right">›</view>
    </view>
    <view class="empty-state" wx:if="{{checkedOut.length === 0}}">
      <view class="empty-state-icon">📋</view>
      <view class="empty-state-text">今日无已出厂访客</view>
    </view>
    <view class="list-footer" wx:if="{{checkedOut.length > 0}}">
      <text class="list-footer-text">已显示 {{checkedOut.length}} 条，共 {{checkedOut.length}} 条</text>
    </view>
  </view>
</view>
