@import "../../app.wxss";

/* 被访人信息区域（只读态） */
.info-section .subsection-title {
  margin-bottom: 16rpx;
}

.info-section .info-row {
  padding: 12rpx 0;
}

.info-value-readonly {
  color: var(--color-text-muted);
  font-size: 28rpx;
  font-weight: 400;
}

/* 表单区域 */
.form-section {
  margin-top: 16rpx;
}

.form-section .subsection-title {
  margin-bottom: 24rpx;
}

/* 错误输入框样式 */
.form-input-error {
  border-color: var(--color-danger) !important;
}
