<view class="container">
  <!-- 被访人信息（只读） -->
  <view class="card-ghost info-section">
    <view class="subsection-title">被访人信息</view>
    <view class="info-row">
      <text class="info-label">被访人</text>
      <text class="info-value-readonly">{{visitInfo.employeeName}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">部门</text>
      <text class="info-value-readonly">{{visitInfo.department || '未填写'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">来访日期</text>
      <text class="info-value-readonly">{{visitInfo.visitDate}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">来访时间</text>
      <text class="info-value-readonly">{{visitInfo.visitTime}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">来访目的</text>
      <text class="info-value-readonly">{{visitInfo.purpose}}</text>
    </view>
  </view>

  <!-- 访客信息表单 -->
  <view class="card form-section">
    <view class="subsection-title">访客信息 <text class="text-muted" style="font-weight:400;">（* 为必填项）</text></view>

    <view class="form-group">
      <text class="form-label form-label-required">姓名</text>
      <input class="form-input {{errors.visitorName ? 'form-input-error' : ''}}" placeholder="请输入您的真实姓名" value="{{form.visitorName}}" data-field="visitorName" bindinput="onInput" bindblur="validateField" />
      <view class="form-error" wx:if="{{errors.visitorName}}">{{errors.visitorName}}</view>
    </view>

    <view class="form-group">
      <text class="form-label form-label-required">手机号</text>
      <input class="form-input {{errors.visitorPhone ? 'form-input-error' : ''}}" type="number" maxlength="11" placeholder="请输入11位手机号" value="{{form.visitorPhone}}" data-field="visitorPhone" bindinput="onInput" bindblur="validateField" />
      <view class="form-error" wx:if="{{errors.visitorPhone}}">{{errors.visitorPhone}}</view>
    </view>

    <view class="form-group">
      <text class="form-label">公司名称</text>
      <input class="form-input" placeholder="请输入公司名称（选填）" value="{{form.visitorCompany}}" data-field="visitorCompany" bindinput="onInput" />
    </view>

    <view class="form-group">
      <text class="form-label form-label-required">拜访日期</text>
      <picker mode="date" value="{{form.visitDate}}" data-field="visitDate" bindchange="onInput">
        <view class="form-input picker-value {{!form.visitDate ? 'placeholder' : ''}}">{{form.visitDate || '请选择日期'}}</view>
      </picker>
    </view>

    <view class="form-group">
      <text class="form-label form-label-required">拜访时间</text>
      <picker mode="time" value="{{form.visitTime}}" data-field="visitTime" bindchange="onInput">
        <view class="form-input picker-value {{!form.visitTime ? 'placeholder' : ''}}">{{form.visitTime || '请选择时间'}}</view>
      </picker>
    </view>

    <view class="form-group">
      <text class="form-label form-label-required">来访目的</text>
      <input class="form-input" placeholder="请输入来访目的" value="{{form.purpose}}" data-field="purpose" bindinput="onInput" />
    </view>

    <view class="form-group">
      <text class="form-label">陪同人姓名</text>
      <input class="form-input" placeholder="如有陪同人请填写" value="{{form.escortName}}" data-field="escortName" bindinput="onInput" />
    </view>

    <view class="form-group">
      <text class="form-label">工牌类型</text>
      <picker value="{{badgeTypes.indexOf(form.badgeType)}}" range="{{badgeTypes}}" bindchange="onBadgeTypeChange">
        <view class="form-input picker-value {{!form.badgeType ? 'placeholder' : ''}}">{{form.badgeType || '请选择工牌类型'}}</view>
      </picker>
    </view>
  </view>

  <button class="btn btn-primary" bindtap="submitForm" disabled="{{!isFormValid}}">提交登记信息</button>
</view>
