/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: #f5f5f5;
  color: #333;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 通用容器 */
.container {
  padding: 30rpx;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 页面标题 */
.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

/* 表单相关 */
.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  border: 2rpx solid transparent;
}

.form-input:focus {
  border-color: #1976d2;
}

/* 按钮 */
.btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn-primary {
  background: #1976d2;
  color: #fff;
}

.btn-primary:active {
  background: #1565c0;
}

.btn-success {
  background: #4caf50;
  color: #fff;
}

.btn-success:active {
  background: #43a047;
}

.btn-danger {
  background: #f44336;
  color: #fff;
}

.btn-danger:active {
  background: #e53935;
}

.btn-default {
  background: #e0e0e0;
  color: #333;
}

.btn-outline {
  background: transparent;
  border: 2rpx solid #1976d2;
  color: #1976d2;
}

.btn-sm {
  width: auto;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 30rpx;
  font-size: 26rpx;
  display: inline-block;
}

/* 状态标签 */
.status-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-pending {
  background: #fff3e0;
  color: #ef6c00;
}

.status-confirmed {
  background: #e3f2fd;
  color: #1976d2;
}

.status-checked-in {
  background: #e8f5e9;
  color: #388e3c;
}

.status-item-checked {
  background: #f3e5f5;
  color: #7b1fa2;
}

.status-checked-out {
  background: #eceff1;
  color: #546e7a;
}

/* 文本工具 */
.text-center { text-align: center; }
.text-right { text-align: right; }
.text-primary { color: #1976d2; }
.text-success { color: #4caf50; }
.text-danger { color: #f44336; }
.text-muted { color: #999; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.font-bold { font-weight: 600; }

/* 间距 */
.mt-1 { margin-top: 10rpx; }
.mt-2 { margin-top: 20rpx; }
.mt-3 { margin-top: 30rpx; }
.mb-1 { margin-bottom: 10rpx; }
.mb-2 { margin-bottom: 20rpx; }
.mb-3 { margin-bottom: 30rpx; }

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-state-icon {
  font-size: 120rpx;
  color: #ddd;
  margin-bottom: 20rpx;
}

.empty-state-text {
  color: #999;
  font-size: 28rpx;
}

/* 分割线 */
.divider {
  height: 1px;
  background: #eee;
  margin: 30rpx 0;
}

/* 列表项 */
.list-item {
  background: #fff;
  padding: 30rpx;
  border-bottom: 1px solid #f5f5f5;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.list-item:last-child {
  border-bottom: none;
}
