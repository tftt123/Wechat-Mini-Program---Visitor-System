/* ============================================================
   访客系统 V2.0 — 企业级设计规范
   主色调：深灰蓝 #1A2A3A | 品牌红 #D32F2F（克制使用）
   背景：#F5F7FA | 卡片：#FFFFFF + 轻阴影
   ============================================================ */

/* CSS 变量 */
page {
  --color-primary: #1A2A3A;
  --color-primary-hover: #0F1A25;
  --color-secondary: #2C3E50;
  --color-surface: #FFFFFF;
  --color-background: #F5F7FA;
  --color-muted: #E8ECF0;
  --color-border: #D1D9E0;
  --color-text-primary: #1A2A3A;
  --color-text-secondary: #4A5568;
  --color-text-muted: #94A3B8;
  --color-brand: #D32F2F;
  --color-brand-hover: #B71C1C;
  --color-brand-light: #FFEBEE;
  --color-success: #16A34A;
  --color-success-light: #DCFCE7;
  --color-warning: #CA8A04;
  --color-warning-light: #FEF3C7;
  --color-danger: #DC2626;
  --color-danger-light: #FEE2E2;
  --color-info: #0369A1;

  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-pill: 999rpx;

  --shadow-card: 0 1rpx 4rpx rgba(26,42,58,0.06);
  --shadow-elevated: 0 4rpx 16rpx rgba(26,42,58,0.10);
  --shadow-modal: 0 8rpx 32rpx rgba(26,42,58,0.14);

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background-color: var(--color-background);
  color: var(--color-text-primary);
  font-size: 28rpx;
  line-height: 1.5;
}

/* 通用容器 */
.container {
  padding: 32rpx;
}

/* 卡片样式 */
.card {
  background: var(--color-surface);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
}

.card-elevated {
  box-shadow: var(--shadow-elevated);
}

.card-highlight {
  border-left: 6rpx solid var(--color-brand);
}

.card-ghost {
  background: transparent;
  box-shadow: none;
  border: none;
  border-bottom: 1rpx solid var(--color-border);
  border-radius: 0;
  padding: 24rpx 0;
  margin-bottom: 0;
}

/* 页面标题 */
.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 32rpx;
}

/* 区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 24rpx;
}

/* 子区块标题 */
.subsection-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

/* 表单相关 */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.form-label-required::after {
  content: ' *';
  color: var(--color-brand);
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: var(--color-surface);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--color-text-primary);
  border: 2rpx solid var(--color-border);
}

.form-input:focus {
  border-color: var(--color-primary);
}

.form-input::placeholder {
  color: var(--color-text-muted);
}

.form-input:disabled {
  background: var(--color-muted);
  color: var(--color-text-muted);
}

.form-error {
  font-size: 24rpx;
  color: var(--color-danger);
  margin-top: 8rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid var(--color-danger);
}

.picker-value {
  display: flex;
  align-items: center;
  height: 88rpx;
  color: var(--color-text-primary);
}

.picker-value.placeholder {
  color: var(--color-text-muted);
}

/* 按钮体系 */
.btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  transition: all 0.15s;
}

.btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn:disabled {
  background: var(--color-muted) !important;
  color: var(--color-text-muted) !important;
  transform: none;
  opacity: 1;
}

/* Primary Dark - 核心操作 */
.btn-primary {
  background: var(--color-primary);
  color: #fff;
}

.btn-primary:active {
  background: var(--color-primary-hover);
}

/* Secondary - 次级操作 */
.btn-secondary {
  background: var(--color-surface);
  color: var(--color-text-primary);
  border: 2rpx solid var(--color-border);
}

.btn-secondary:active {
  background: var(--color-background);
}

/* Success - 正向完成 */
.btn-success {
  background: var(--color-success);
  color: #fff;
}

.btn-success:active {
  background: #15803D;
}

/* Brand/Red - 极度克制，仅危险操作 */
.btn-brand {
  background: var(--color-brand);
  color: #fff;
}

.btn-brand:active {
  background: var(--color-brand-hover);
}

/* Danger - 删除/作废 */
.btn-danger {
  background: var(--color-danger);
  color: #fff;
}

.btn-danger:active {
  background: #B91C1C;
}

/* Danger Light - 克制的危险操作 */
.btn-danger-light {
  background: var(--color-danger-light);
  color: var(--color-danger);
}

.btn-danger-light:active {
  background: #FECACA;
}

/* Default - 灰色 */
.btn-default {
  background: var(--color-muted);
  color: var(--color-text-primary);
}

/* Outline - 白底描边 */
.btn-outline {
  background: transparent;
  border: 2rpx solid var(--color-border);
  color: var(--color-text-primary);
}

.btn-outline:active {
  background: var(--color-background);
}

/* Ghost - 纯文字 */
.btn-ghost {
  background: transparent;
  color: var(--color-text-secondary);
}

.btn-ghost:active {
  color: var(--color-text-primary);
}

/* 小按钮 */
.btn-sm {
  width: auto;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 32rpx;
  font-size: 26rpx;
  display: inline-block;
}

/* 中按钮 */
.btn-md {
  width: auto;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 40rpx;
  font-size: 28rpx;
  display: inline-block;
}

/* 状态标签体系 — 语义化配色 */
.status-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  font-weight: 500;
}

/* 待访客填表 - 灰 */
.status-awaiting {
  background: #F1F5F9;
  color: #94A3B8;
}

/* 待确认 - 黄 */
.status-pending {
  background: var(--color-warning-light);
  color: var(--color-warning);
}

/* 已确认 - 深灰 */
.status-confirmed {
  background: #E2E8F0;
  color: var(--color-primary);
}

/* 已入厂 - 绿 */
.status-checked-in {
  background: var(--color-success-light);
  color: var(--color-success);
}

/* 待出厂 - 红（唯一红色状态标签） */
.status-item-checked {
  background: var(--color-brand-light);
  color: var(--color-brand);
}

/* 已出厂 - 灰 */
.status-checked-out {
  background: #F1F5F9;
  color: #64748B;
}

/* 已作废 - 灰+中划线 */
.status-cancelled {
  background: #F1F5F9;
  color: #94A3B8;
  text-decoration: line-through;
}

/* 文本工具 */
.text-center { text-align: center; }
.text-right { text-align: right; }
.text-primary { color: var(--color-text-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-muted { color: var(--color-text-muted); }
.text-brand { color: var(--color-brand); }
.text-success { color: var(--color-success); }
.text-warning { color: var(--color-warning); }
.text-danger { color: var(--color-danger); }
.text-info { color: var(--color-info); }

.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 48rpx; }
.text-3xl { font-size: 64rpx; }

.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }

/* 间距 */
.mt-1 { margin-top: 8rpx; }
.mt-2 { margin-top: 16rpx; }
.mt-3 { margin-top: 24rpx; }
.mt-4 { margin-top: 32rpx; }
.mt-5 { margin-top: 48rpx; }
.mb-1 { margin-bottom: 8rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mb-3 { margin-bottom: 24rpx; }
.mb-4 { margin-bottom: 32rpx; }
.mb-5 { margin-bottom: 48rpx; }

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-state-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  color: var(--color-text-muted);
}

.empty-state-text {
  color: var(--color-text-muted);
  font-size: 28rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 32rpx 0;
}

.divider-text {
  display: flex;
  align-items: center;
  color: var(--color-text-muted);
  font-size: 26rpx;
}

.divider-text::before,
.divider-text::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: var(--color-border);
}

.divider-text::before { margin-right: 20rpx; }
.divider-text::after { margin-left: 20rpx; }

/* 列表项 */
.list-item {
  background: var(--color-surface);
  padding: 24rpx;
  border-bottom: 1rpx solid var(--color-border);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.list-item:last-child {
  border-bottom: none;
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: var(--color-text-secondary);
  font-size: 28rpx;
}

.info-value {
  color: var(--color-text-primary);
  font-size: 28rpx;
  font-weight: 500;
}

/* 上传区域 */
.upload-area {
  width: 120rpx;
  height: 120rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-surface);
}

.upload-area:active {
  border-color: var(--color-primary);
}

/* 邀请码大字符 */
.invite-code-display {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  letter-spacing: 16rpx;
  text-align: center;
  padding: 48rpx 32rpx;
  background: var(--color-background);
  border-radius: var(--radius-md);
}

/* Tab 栏样式 */
.tab-bar {
  display: flex;
  background: var(--color-surface);
  border-radius: var(--radius-sm);
  padding: 4rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--color-border);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--color-text-muted);
  border-radius: var(--radius-sm);
  position: relative;
}

.tab-item.active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 500;
}

.tab-badge {
  display: inline-block;
  width: 16rpx;
  height: 16rpx;
  background: var(--color-brand);
  border-radius: 50%;
  margin-left: 4rpx;
  vertical-align: middle;
}

/* 品牌竖线 */
.brand-line {
  display: inline-block;
  width: 6rpx;
  height: 36rpx;
  background: var(--color-brand);
  border-radius: 3rpx;
  margin-right: 12rpx;
  vertical-align: middle;
}

/* 时间线 */
.timeline {
  position: relative;
  padding-left: 32rpx;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 8rpx;
  bottom: 8rpx;
  width: 2rpx;
  background: var(--color-border);
}

.timeline-item {
  position: relative;
  padding-bottom: 24rpx;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: -28rpx;
  top: 8rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-muted);
  border: 2rpx solid var(--color-border);
}

.timeline-item.completed::before {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.timeline-item.current::before {
  background: var(--color-surface);
  border-color: var(--color-primary);
  border-width: 4rpx;
}

/* 角标 */
.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: var(--radius-pill);
  font-size: 20rpx;
  font-weight: 600;
}

.badge-red {
  background: var(--color-brand);
  color: #fff;
}

.badge-gray {
  background: var(--color-muted);
  color: var(--color-text-secondary);
}

/* 统计卡片 */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stats-card {
  flex: 1;
  background: var(--color-surface);
  border-radius: var(--radius-md);
  padding: 24rpx;
  text-align: center;
  border: 1rpx solid var(--color-border);
}

.stats-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.2;
}

.stats-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

/* 列表项通用 */
.visit-item {
  position: relative;
}

.visit-item .item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.visit-item .item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.visit-item .item-info {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.visit-item .item-purpose {
  font-size: 26rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

/* 箭头指示 */
.arrow-right {
  color: var(--color-border);
  font-size: 28rpx;
}
